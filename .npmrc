# Match the install behavior the lockfile was generated with.
#
# `legacy-peer-deps=true` tolerates peerOptional conflicts that npm 10+ would
# otherwise reject. Today the only conflict is `@eslint/js@10` peerOptional
# requesting `eslint@^10` while the project ships `eslint@^9`. That mismatch
# is benign (peerOptional, not peer) but a strict `npm ci` rejects it.
#
# TODO(eslint): bump `eslint` to `^10` once the flat-config + plugin ecosystem
# (eslint-plugin-react, eslint-plugin-jsx-a11y, typescript-eslint) all
# support it without warnings. Track in a separate PR.
legacy-peer-deps=true

# Strict-SSL is the default; we just make it explicit.
strict-ssl=true

# Save exact versions on `npm install <pkg>` so we don't introduce caret
# floats outside of conscious decisions.
save-exact=false
