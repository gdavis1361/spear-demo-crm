{
  "name": "spear-demo-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Spear CRM — redesigned for how moves actually work.",
  "homepage": "https://github.com/gdavis1361/spear-demo-crm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gdavis1361/spear-demo-crm.git"
  },
  "bugs": {
    "url": "https://github.com/gdavis1361/spear-demo-crm/issues"
  },
  "author": "Spear team",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium-smoke",
    "test:visual": "playwright test --project=chromium-visual",
    "test:visual:update": "playwright test --project=chromium-visual --update-snapshots",
    "size": "size-limit",
    "seed": "tsx src/seeds/cli.ts",
    "sbom": "npm sbom --sbom-format=spdx --omit=dev > sbom.spdx.json",
    "audit:supply-chain": "npm audit signatures && npm audit --audit-level=high --omit=dev",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@sentry/react": "^10.48.0",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^11.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "size-limit": "^12.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.11",
    "vitest": "^4.1.4"
  }
}
